# NetForge API — environment configuration
# Copy to .env and edit before running.

# Address and port to listen on (default: :8090)
NETFORGE_ADDR=:8090

# Comma-separated list of valid Bearer tokens.
# Generate with: openssl rand -hex 32
NETFORGE_API_TOKENS=changeme,another-token

# nftables table name (default: netforge)
NETFORGE_NFT_TABLE=netforge

# Log level: debug | info | warn | error (default: info)
NETFORGE_LOG_LEVEL=info

# Skip kernel calls — useful for development without root (default: false)
NETFORGE_DRY_RUN=false
